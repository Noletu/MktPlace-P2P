# Server
PORT=3001
NODE_ENV=development

# SECURITY: Origens permitidas (CORS) - separadas por virgula
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (SQLite para desenvolvimento)
DATABASE_URL="file:./dev.db"

# Redis (opcional - blacklist de tokens)
REDIS_URL=redis://localhost:6379

# JWT - OBRIGATORIO
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERAR_SEU_JWT_SECRET_AQUI
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 2FA (TOTP)
TWO_FACTOR_ISSUER=Mktplace da Liberdade
TWO_FACTOR_WINDOW=1
# Desabilitar 2FA em desenvolvimento (true = pula validacao do codigo)
SKIP_2FA=false

# Dual Approval - Maker Checker
# Tempo minimo de espera antes do override de emergencia (em minutos)
DUAL_APPROVAL_OVERRIDE_MIN_WAIT_MINUTES=60

# Blockchain RPC URLs
SOLANA_RPC_URL=https://api.devnet.solana.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# HD Wallet System - OBRIGATORIO
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=GERAR_SUA_WALLET_KEY_AQUI

# HD Wallet - Master Seed (gerado pelo sistema via admin)
MASTER_SEED_ENCRYPTED=

# SMTP (Email) - opcional em desenvolvimento (usa Ethereal fake SMTP se nao configurado)
# Para Gmail: gere uma "Senha de App" em https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MktPlace da Liberdade <noreply@mktplace.com>"

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:3000

# reCAPTCHA (opcional em desenvolvimento)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
# Forcar validacao de captcha mesmo em dev (true = obrigatorio)
RECAPTCHA_REQUIRED=false
