# Server
PORT=3002
NODE_ENV=development

# SECURITY: Origens permitidas (CORS) - separadas por virgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Database
# Development: SQLite
# Production: PostgreSQL (ex: postgresql://user:password@host:5432/database)
DATABASE_URL="file:./dev.db"

# Redis (opcional - para blacklist de tokens e cache)
REDIS_URL=redis://localhost:6379

# JWT
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERAR_SEU_JWT_SECRET_AQUI
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Blockchain RPC URLs (testnet para desenvolvimento)
SOLANA_RPC_URL=https://api.devnet.solana.com
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
TRON_RPC_URL=https://api.shasta.trongrid.io

# CoinGecko API (opcional no MVP)
COINGECKO_API_KEY=

# Google Cloud Vision OCR
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# 2FA
TWO_FACTOR_ISSUER=Mktplace da Liberdade
TWO_FACTOR_WINDOW=1

# CAPTCHA
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# HD Wallet System
# SECURITY: MASTER_SEED_ENCRYPTION_KEY deve ficar em .env.keys (separado)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=GERAR_SUA_WALLET_KEY_AQUI

# HD Wallet System - Master Seed Criptografado
# Gerado automaticamente pelo sistema ao configurar master seed via admin
MASTER_SEED_ENCRYPTED=MASTER_SEED_ENCRYPTED=6d37265450763dcf688b99a5:b2fc1404d5ac77b9cd4ed377f334be86:02cb7caf232e6aec57101a26f48a94e8ba7ca333a7568751286f774fd5f7c1f46606a837de79a215622e48f419cf36d21e5188ec9423249ec14e342c1641378a

# SMTP (Email) - Gmail com App Password
# Para Gmail: gere uma "Senha de App" em https://myaccount.google.com/apppasswords
# Sem estas variaveis, o sistema usa Ethereal (fake SMTP para desenvolvimento)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="MktPlace da Liberdade <seu-email@gmail.com>"

# Frontend URL (para links em emails de reset, boas-vindas, etc)
FRONTEND_URL=http://localhost:3000
