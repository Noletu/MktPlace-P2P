# Server
PORT=3001
NODE_ENV=development

# SECURITY: Origens permitidas (CORS) - separadas por vírgula
# DESENVOLVIMENTO: localhost automático | PRODUÇÃO: Domínios específicos
# Exemplo: https://mktplace.com.br,https://www.mktplace.com.br
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# Development: SQLite
# Production: PostgreSQL (ex: postgresql://user:password@host:5432/database)
DATABASE_URL="file:./dev.db"

# Redis (opcional - para blacklist de tokens e cache)
REDIS_URL=redis://localhost:6379

# JWT - SECURITY: NUNCA commitar o JWT_SECRET real
# OBRIGATÓRIO: Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# PRODUÇÃO: Mínimo 64 caracteres | DESENVOLVIMENTO: Mínimo 32 caracteres
# EXEMPLO (NÃO USAR EM PRODUÇÃO): 407a02fb444fd7a971a1d21983e5db4506f90ec2eada026ad247b8e18799c68cd8197771b7138dc95ee31b6d0252cefa7cfe890a8b81767ce2fb4887ba24683f
JWT_SECRET=407a02fb444fd7a971a1d21983e5db4506f90ec2eada026ad247b8e18799c68cd8197771b7138dc95ee31b6d0252cefa7cfe890a8b81767ce2fb4887ba24683f
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Blockchain RPC URLs (testnet para desenvolvimento)
SOLANA_RPC_URL=https://api.devnet.solana.com
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
TRON_RPC_URL=https://api.shasta.trongrid.io

# CoinGecko API (opcional no MVP)
COINGECKO_API_KEY=

# Google Cloud Vision OCR (configurar para validação de comprovantes)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# 2FA (configurar quando implementado)
TWO_FACTOR_ISSUER=Mktplace da Liberdade
TWO_FACTOR_WINDOW=1

# CAPTCHA (configurar quando implementado)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# HD Wallet System - Chaves de Criptografia
# ATENÇÃO: Nunca compartilhe estas chaves em produção! Guardar em local seguro!
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_SEED_ENCRYPTION_KEY=ad28b3150dccf25ad6509c073480a080157dc56c8fff76e363e5aded2d469d21
WALLET_ENCRYPTION_KEY=ab23dd7b3ac124b32837d4573c7eb2a515c1a5f13b5a638f9ab440ec4cd2b2be

