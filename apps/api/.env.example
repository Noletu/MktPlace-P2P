# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
# Development: SQLite
# Production: PostgreSQL (ex: postgresql://user:password@host:5432/database)
DATABASE_URL="file:./dev.db"

# Redis (opcional - para blacklist de tokens e cache)
REDIS_URL=redis://localhost:6379

# JWT - SECURITY: NUNCA commitar o JWT_SECRET real
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<GERAR_SECRET_SEGURO_AQUI>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Blockchain RPC URLs (testnet para desenvolvimento)
SOLANA_RPC_URL=https://api.devnet.solana.com
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
TRON_RPC_URL=https://api.shasta.trongrid.io

# CoinGecko API (opcional no MVP)
COINGECKO_API_KEY=

# Google Cloud Vision OCR (configurar para validação de comprovantes)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# 2FA (configurar quando implementado)
TWO_FACTOR_ISSUER=Mktplace da Liberdade
TWO_FACTOR_WINDOW=1

# CAPTCHA (configurar quando implementado)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
