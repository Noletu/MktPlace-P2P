// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
  cpf      String? @unique
  phone    String?

  // Reputation
  reputationScore        Int @default(0)
  totalTransactions      Int @default(0)
  successfulTransactions Int @default(0)

  // Custom daily limit (admin override)
  customDailyLimit    Float?    // DEPRECATED: usar customDailyLimitStr (Float causa arredondamentos)
  customDailyLimitStr String?   // MIGRATION (H-8): substitui customDailyLimit com precisão correta
  customLimitSetBy    String?   // ID do admin que definiu
  customLimitSetAt    DateTime? // Quando foi definido
  customLimitNote     String?   // Nota do admin (motivo)

  // Cancellation tracking
  totalCancellations  Int       @default(0) // Total histórico de cancelamentos
  recentCancellations Int       @default(0) // Cancelamentos nos últimos 30 dias
  lastCancellationAt  DateTime? // Data do último cancelamento

  // RBAC: Relacionamento com Role (migration: manter role string temporariamente)
  roleId String? // Foreign key para Role
  role   Role?   @relation(fields: [roleId], references: [id])

  // DEPRECATED: Role string (será removido após migration)
  // Mantido temporariamente para compatibilidade durante migração
  legacyRole String @default("USER")

  // SECURITY: 2FA
  twoFactorEnabled     Boolean @default(false)
  twoFactorSecret      String?
  twoFactorTempSecret  String? // Secret temporário durante setup
  twoFactorBackupCodes String? // JSON array de códigos hasheados

  // PASSWORD RESET
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // ADMIN CONTROLS: Account Freeze (Congelamento de conta)
  accountFrozen Boolean   @default(false) // Se conta está congelada
  frozenReason  String? // Motivo do congelamento
  frozenAt      DateTime? // Quando foi congelada
  frozenBy      String? // ID do admin que congelou
  frozenUntil   DateTime? // Data/hora para auto-desbloqueio (null = permanente)

  // Notification Preferences (JSON: category → 'both'|'email'|'push'|'none')
  notificationPreferences String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações atualizadas para HD Wallet
  userWallets           UserWallet[]
  orders                Order[]
  transactions          Transaction[]          @relation("payer")
  reviews               Review[]               @relation("reviewer")
  reviewsReceived       Review[]               @relation("reviewed")
  refreshTokens         RefreshToken[]
  adminActions          AdminAction[]
  walletTransactions    WalletTransaction[]

  // Disputas
  disputesCreated  Dispute[]        @relation("DisputeCreator")
  disputesResolved Dispute[]        @relation("DisputeResolver")
  disputeMessages  DisputeMessage[] @relation("DisputeMessageAuthor")

  // Tickets de Suporte
  ticketsCreated  SupportTicket[]  @relation("TicketCreator")
  ticketsResolved SupportTicket[]  @relation("TicketResolver")
  ticketMessages  TicketMessage[]  @relation("TicketMessageAuthor")

  // Notificações
  notifications Notification[] @relation("notifications")

  // Chat
  chatsAsParticipant1 Chat[]        @relation("ChatParticipant1")
  chatsAsParticipant2 Chat[]        @relation("ChatParticipant2")
  chatMessages        ChatMessage[] @relation("ChatMessageSender")

  // Encryption Keys (1:1 relationship)
  userKeys UserKeys?

  // Cancellation history
  cancellationHistory CancellationHistory[]

  // Coupon system
  userCoupons UserCoupon[]

  // Dual-Approval system
  pendingApprovalsInitiated PendingApproval[]  @relation("PendingApprovalInitiator")
  pendingApprovalsApproved  PendingApproval[]  @relation("PendingApprovalApprover")
  delegationsGranted        MasterDelegation[] @relation("DelegationGrantor")
  delegationsReceived       MasterDelegation[] @relation("DelegationGrantee")
  delegationsRevoked        MasterDelegation[] @relation("DelegationRevoker")
}

// ============================================
// HD WALLET SYSTEM - Nova Implementação
// ============================================

// Carteiras HD gerenciadas pela plataforma (BIP32/BIP44)
model UserWallet {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tipo de cripto e rede
  cryptoType String // BTC, USDC, USDT
  network    String // BITCOIN, BASE, SOLANA

  // Endereço derivado (HD Wallet)
  address        String // Endereço público derivado
  derivationPath String // Ex: m/44'/60'/0'/0/0 (BIP44)

  // SECURITY: Private key criptografada com AES-256-GCM
  encryptedPrivateKey String // Private key criptografada (nunca em plain text!)

  // Controle de saldo (consultado on-chain + bloqueios locais)
  balance          Decimal @default(0) @db.Decimal(38, 18) // Saldo total on-chain
  lockedBalance    Decimal @default(0) @db.Decimal(38, 18) // Bloqueado em pedidos ativos
  availableBalance Decimal @default(0) @db.Decimal(38, 18) // Disponível = balance - locked

  // Estatísticas
  totalDeposited Decimal @default(0) @db.Decimal(38, 18) // Total depositado historicamente
  totalWithdrawn Decimal @default(0) @db.Decimal(38, 18) // Total sacado
  totalUsed      Decimal @default(0) @db.Decimal(38, 18) // Total usado como colateral

  // Sincronização blockchain
  lastSyncedAt    DateTime? // Última vez que saldo foi sincronizado
  lastBlockHeight Int?      // Último bloco verificado

  // Omnibus / Sweep (Hot Wallet Architecture)
  onChainSnapshot    Decimal   @default(0) @db.Decimal(38, 18) // Último saldo on-chain conhecido (separado do ledger)
  lastSweptAt        DateTime?                                  // Quando fundos foram varridos para hot wallet
  sweepStatus        String    @default("NONE")                // NONE | PENDING | GAS_FUNDING | SWEEPING | COMPLETED | FAILED
  pendingSweepAmount Decimal   @default(0) @db.Decimal(38, 18) // Valor aguardando sweep

  // Estado
  isActive Boolean @default(true)

  // Auditoria de criação — rastreia QUEM/O QUE criou esta wallet
  creationSource  String? // MANUAL, DEPOSIT_WIZARD, ORDER_SELL, ORDER_BUY, COLLATERAL_GENERATE, INTERNAL_BALANCE, SYSTEM
  creationDetails String? // JSON com contexto extra (endpoint, orderId, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  ordersAsCollateral Order[]             @relation("WalletCollateral")
  transactions       WalletTransaction[]
  withdrawals        Withdrawal[]
  sweepTransactions  SweepTransaction[]

  @@unique([userId, cryptoType, network])
  @@index([userId])
  @@index([address])
  @@index([cryptoType, network])
  @@index([isActive])
}

// Histórico completo de transações de carteira (auditoria)
model WalletTransaction {
  id String @id @default(cuid())

  // Carteira e usuário
  walletId String
  wallet   UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pedido relacionado (opcional)
  orderId String?
  order   Order?  @relation("WalletTransactionOrder", fields: [orderId], references: [id])

  // Tipo de transação
  // DEPOSIT, LOCK, UNLOCK, DEDUCT, WITHDRAWAL, FEE, REFUND
  // ADMIN_DEBIT, ADMIN_CREDIT, ADMIN_ADJUSTMENT, ADMIN_FREEZE, ADMIN_UNFREEZE
  type String

  // Valores
  amount        Decimal  @db.Decimal(38, 18) // Valor da transação
  balanceBefore Decimal  @db.Decimal(38, 18) // Saldo total antes
  balanceAfter  Decimal  @db.Decimal(38, 18) // Saldo total depois
  lockedBefore  Decimal? @db.Decimal(38, 18) // Saldo bloqueado antes (para LOCK/UNLOCK)
  lockedAfter   Decimal? @db.Decimal(38, 18) // Saldo bloqueado depois

  // Blockchain (se aplicável)
  txHash        String? // Hash da transação blockchain
  blockHeight   Int? // Altura do bloco
  confirmations Int? // Número de confirmações

  // ADMIN CONTROLS: Operações administrativas
  adminUserId  String? // ID do admin que executou (para operações admin)
  adminReason  String? // Motivo da operação administrativa
  relatedTxId  String? // Link para transação relacionada (debit/credit pair)

  // Metadados
  description String? // Descrição legível
  metadata    String? // JSON com dados adicionais

  createdAt DateTime @default(now())

  @@unique([txHash]) // SECURITY: Prevenir replay attack — mesmo txHash não pode ser creditado duas vezes
  @@index([walletId])
  @@index([userId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

// Saques de carteira
model Withdrawal {
  id       String @id @default(cuid())
  walletId String
  wallet   UserWallet @relation(fields: [walletId], references: [id])

  toAddress String
  amount    Decimal @db.Decimal(38, 18)

  // Blockchain
  txHash String? @unique
  status String  @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, REQUIRES_APPROVAL, APPROVED, REJECTED

  // Taxas
  networkFee  Decimal? @db.Decimal(38, 18) // Taxa de rede
  platformFee Decimal? @db.Decimal(38, 18) // Taxa da plataforma

  // Admin review (para saques que requerem aprovação)
  reviewedBy String?   // ID do admin que revisou
  reviewNote String?   // Nota do admin
  reviewedAt DateTime? // Quando foi revisado

  // Retry tracking
  retryCount Int    @default(0) // Quantas vezes tentou processar
  lastError  String? // Último erro de processamento

  createdAt   DateTime  @default(now())
  processedAt DateTime?
  completedAt DateTime?

  @@index([walletId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// ORDERS - Atualizado para HD Wallet
// ============================================

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Order Type - BUY (user wants to buy crypto) or SELL (user wants to sell crypto)
  orderType String @default("SELL")

  // Payment Method - BOLETO, PIX (for SELL orders, provider sets for BUY orders)
  type   String
  // Status - PENDING, MATCHED, IN_NEGOTIATION, PAYMENT_SENT, VALIDATING, COMPLETED, DISPUTED, CANCELLED, TIMEOUT, EXPIRED
  status String @default("PENDING")

  // Crypto side
  cryptoType    String
  cryptoNetwork String
  cryptoAmount  Decimal @db.Decimal(38, 18)

  // BRL side
  brlAmount Decimal @db.Decimal(38, 18)

  // Fee calculation
  platformFee Decimal @db.Decimal(38, 18)
  payerReward Decimal @db.Decimal(38, 18)
  totalFee    Decimal @db.Decimal(38, 18)

  // Coupon discount tracking
  appliedCouponId        String?  // ID do cupom aplicado
  appliedCouponCode      String?  // Código do cupom (denormalizado para histórico)
  appliedCouponDiscount  Int?     // Percentual aplicado (snapshot)
  originalPlatformFee    Decimal? @db.Decimal(38, 18) // Taxa original antes do desconto
  discountAmount         Decimal? @db.Decimal(38, 18) // Valor economizado

  // Order specific data (JSON string)
  orderData String

  // HD WALLET COLLATERAL SYSTEM (Novo)
  walletId               String? // ID da carteira HD usada para colateral
  wallet                 UserWallet? @relation("WalletCollateral", fields: [walletId], references: [id])
  collateralSource       String? // Fonte do colateral: HD_WALLET, EXTERNAL_DEPOSIT (legacy)
  collateralConfirmed    Boolean  @default(false) // Se o colateral foi confirmado
  collateralLocked       Boolean  @default(false) // Se o colateral está bloqueado
  collateralLockedAmount Decimal? @db.Decimal(38, 18) // Valor bloqueado
  collateralUnlockedAt   DateTime? // Quando foi desbloqueado

  // Just-in-time deposit (híbrido)
  awaitingDeposit       Boolean @default(false) // Se está aguardando depósito inicial
  depositDeadline       DateTime? // Prazo para depositar
  depositConfirmedAt    DateTime? // Quando depósito foi confirmado

  // Timeout handling
  timeoutAt      DateTime?
  paidByPlatform Boolean   @default(false)

  // Expiration customization (PIX)
  customExpirationHours Int? // Usuário define prazo para PIX
  manualCancelOnly      Boolean @default(false) // PIX sem prazo automático

  // Refund system
  refundStatus        String    @default("NOT_REQUIRED") // NOT_REQUIRED, PENDING_USER_CHOICE, PROCESSING, COMPLETED, FAILED
  refundMethod        String?  // BLOCKCHAIN, INTERNAL_CREDIT
  refundTxHash        String?  // Hash da transação de devolução
  refundAmount        Decimal? @db.Decimal(38, 18) // Valor devolvido (após taxas)
  refundNetworkFee    Decimal? @db.Decimal(38, 18) // Taxa de rede cobrada
  refundProcessingFee Decimal? @db.Decimal(38, 18) // Taxa de processamento (margem)
  refundedAt          DateTime?
  cancelReason        String? // AUTO_EXPIRED_BOLETO, AUTO_EXPIRED_PIX, USER_CANCELLED

  // Crypto Transfer Tracking (Internal Transfer)
  cryptoTransferred   Boolean   @default(false) // Se a cripto foi transferida para o comprador
  cryptoTransferredAt DateTime? // Quando foi transferida
  cryptoTransferredTo String? // userId do comprador que recebeu a cripto

  // Cancellation details
  cancelledBy         String? // userId de quem cancelou
  cancellationReason  String? // Motivo categorizado (USER_CHANGED_MIND, FOUND_BETTER_PRICE, etc)
  cancellationNote    String? // Observação adicional do usuário

  // Negotiation system
  negotiatingUserId    String? // Quem está negociando agora (reserva por 10min)
  negotiationStartedAt DateTime? // Quando negociação iniciou

  // BUY ORDER SYSTEM - Provider (liquidity provider) tracking
  providerId       String? // userId do provedor que aceitou ordem BUY
  providerWalletId String? // walletId do provedor (para colateral em ordens BUY)

  // Presence system (por pedido)
  ownerOnline         Boolean  @default(false) // Toggle manual do vendedor
  ownerLastSeenAt     DateTime @default(now()) // Último heartbeat recebido
  ownerLastActivityAt DateTime @default(now()) // Última mudança de toggle

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  transactions           Transaction[]
  disputes               Dispute[]
  reviews                Review[]
  chat                   Chat?
  walletTransactions     WalletTransaction[] @relation("WalletTransactionOrder")
  cancellationHistory    CancellationHistory[]

  @@index([userId])
  @@index([status])
  @@index([walletId])
  @@index([negotiatingUserId])
  @@index([negotiationStartedAt])
  @@index([ownerOnline])
  @@index([ownerLastSeenAt])
  @@index([awaitingDeposit])
  @@index([providerId])
}

model Transaction {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  payerId String
  payer   User   @relation("payer", fields: [payerId], references: [id])

  // Status - PENDING, VALIDATING, APPROVED, REJECTED, DISPUTED
  status String @default("PENDING")

  // Comprovante
  comprovanteUrl  String?
  comprovanteData String?

  // Validation
  validationScore   Int?
  validatedBy       String?
  validatedAt       DateTime?
  validationDeadline DateTime? // Auto-rejeita se admin não validar até esta data

  // Dispute
  disputeReason String?
  disputeData   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fees     Fee[]
  disputes Dispute[]
  reviews  Review[]
}

model Fee {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  type          String
  cryptoType    String
  cryptoAmount  Decimal @db.Decimal(38, 18)
  brlEquivalent Decimal @db.Decimal(38, 18)

  createdAt DateTime @default(now())
}

// ============================================
// PLATFORM WALLETS - Carteiras dos Sócios (MASTER/ADMIN)
// ============================================

// Carteiras HD da plataforma derivadas da master seed (Account 0)
// Usadas para: 1) Receber fees das transações, 2) Depósitos dos sócios (cold → hot)
// Compartilhadas entre MASTER e ADMIN (ambos têm acesso)
model PlatformWallet {
  id String @id @default(cuid())

  cryptoType String // BTC, USDT, USDC
  network    String // BITCOIN, BASE, SOLANA

  // Endereço derivado da master seed (Account 0 = Platform)
  address        String // Endereço público derivado (mesmo endereço para USDT/USDC na mesma rede)
  derivationPath String // Ex: m/84'/0'/0'/0/0 (Account 0 = Platform)
  accountIndex   Int    @default(0) // Sempre 0 para platform wallets

  // SECURITY: Private key criptografada com AES-256-GCM
  encryptedPrivateKey String // Private key criptografada

  // Saldo (atualizado via sync blockchain)
  balance          Decimal @default(0) @db.Decimal(38, 18) // Saldo on-chain
  availableBalance Decimal @default(0) @db.Decimal(38, 18) // Disponível (após reservas)

  // Estatísticas (fees acumuladas)
  totalFeesCollected Decimal @default(0) @db.Decimal(38, 18) // Total de fees recebidas
  totalDeposited     Decimal @default(0) @db.Decimal(38, 18) // Total depositado pelos sócios
  totalWithdrawn     Decimal @default(0) @db.Decimal(38, 18) // Total sacado pelos sócios
  totalRefunded      Decimal @default(0) @db.Decimal(38, 18) // Total reembolsado (platform → user)
  totalCollected     Decimal @default(0) @db.Decimal(38, 18) // Total cobrado de usuarios (user → platform)

  // Sincronização blockchain
  lastSyncedAt    DateTime? // Última sincronização
  lastBlockHeight Int? // Último bloco verificado

  // Estado
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transfers         PlatformTransfer[]
  sweepTransactions SweepTransaction[]
  movements         PlatformWalletMovement[]

  @@unique([cryptoType, network])
  @@index([cryptoType])
  @@index([network])
  @@index([address])
  @@index([isActive])
}

// ============================================
// TRANSFERÊNCIAS DA PLATAFORMA (Hot → Cold / Externo)
// ============================================

model PlatformTransfer {
  id String @id @default(cuid())

  platformWalletId String
  platformWallet   PlatformWallet @relation(fields: [platformWalletId], references: [id])

  toAddress   String   // Endereço destino (cold wallet, etc)
  amount      Decimal  @db.Decimal(38, 18) // Valor enviado
  networkFee  Decimal? @db.Decimal(38, 18) // Fee de rede paga
  txHash      String?  // Hash da transação on-chain
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED

  // Quem solicitou
  requestedBy String   // Admin/Master userId
  approvedBy  String?  // Outro admin que aprovou (se dual-approval)
  note        String?  // Nota opcional

  // Erro/retry
  lastError   String?
  retryCount  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  @@index([platformWalletId])
  @@index([status])
  @@index([requestedBy])
}

// ============================================
// MOVIMENTAÇÕES DA PLATFORM WALLET (Ledger completo)
// ============================================

// Registra TODA movimentação de saldo na platform wallet (entradas, saídas, fees)
model PlatformWalletMovement {
  id String @id @default(cuid())

  platformWalletId String
  platformWallet   PlatformWallet @relation(fields: [platformWalletId], references: [id])

  // Tipo de movimentação
  type String // FEE_RECEIVED, SWEEP_IN, WITHDRAWAL_OUT, TRANSFER_OUT, DEPOSIT_IN, BALANCE_SYNC

  // Direção e valor
  direction String // IN, OUT
  amount    Decimal @db.Decimal(38, 18) // Valor absoluto da movimentação

  // Saldos antes/depois (para auditoria)
  balanceBefore Decimal @db.Decimal(38, 18)
  balanceAfter  Decimal @db.Decimal(38, 18)

  // Referências opcionais (para rastreabilidade)
  orderId    String? // ID do order (para fees)
  txHash     String? // Hash on-chain (para sweeps, withdrawals, transfers)
  toAddress  String? // Endereço destino (para saídas)
  fromAddress String? // Endereço origem (para entradas)
  userId     String? // Usuário relacionado (para sweeps, withdrawals)

  // Descrição legível
  description String

  // Metadata adicional (JSON)
  metadata String?

  createdAt DateTime @default(now())

  @@index([platformWalletId])
  @@index([type])
  @@index([direction])
  @@index([createdAt])
  @@index([orderId])
}

// ============================================
// SWEEP TRANSACTIONS - Omnibus Hot Wallet
// ============================================

// Registra cada operação de sweep (user wallet → hot wallet)
model SweepTransaction {
  id                 String   @id @default(cuid())

  // Carteira de origem (usuário)
  userWalletId       String
  userWallet         UserWallet @relation(fields: [userWalletId], references: [id])

  // Carteira destino (hot wallet da plataforma)
  platformWalletId   String
  platformWallet     PlatformWallet @relation(fields: [platformWalletId], references: [id])

  // Tipo de ativo
  cryptoType         String   // BTC, USDT, USDC
  network            String   // BITCOIN, ETHEREUM, BASE, ARBITRUM, SOLANA

  // Valor varrido
  amount             Decimal @db.Decimal(38, 18)

  // Gas funding (para tokens ERC-20/SPL que precisam de moeda nativa para gas)
  gasFundingTxHash   String?
  gasFundingAmount   Decimal? @db.Decimal(38, 18)
  gasFundingStatus   String?  // PENDING | CONFIRMED | FAILED

  // Transação de sweep principal
  sweepTxHash        String?  @unique
  status             String   @default("PENDING") // PENDING | GAS_FUNDING | GAS_CONFIRMED | SWEEPING | COMPLETED | FAILED

  // Erro e retry
  lastError          String?
  retryCount         Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  completedAt        DateTime?

  @@index([userWalletId])
  @@index([platformWalletId])
  @@index([status])
}

// ============================================
// REVIEWS, DISPUTES, NOTIFICATIONS - Mantidos
// ============================================

// Sistema completo de Avaliações/Reviews
model Review {
  id String @id @default(cuid())

  // Quem avalia e quem é avaliado
  reviewerId String
  reviewer   User   @relation("reviewer", fields: [reviewerId], references: [id])

  reviewedId String
  reviewed   User   @relation("reviewed", fields: [reviewedId], references: [id])

  // Relacionamento com pedido/transação
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  // Avaliação geral (1-5 estrelas)
  rating Int // 1-5

  // Avaliações por categoria (opcional, 1-5)
  reliabilityRating   Int? // Confiabilidade
  communicationRating Int? // Comunicação
  speedRating         Int? // Rapidez

  // Comentário
  comment String?

  // Resposta do avaliado
  response    String?
  respondedAt DateTime?

  // Flags
  isSuspicious Boolean @default(false) // Review suspeita (possível fraude)
  isHidden     Boolean @default(false) // Oculta por admin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reviewerId, orderId]) // Um usuário só pode avaliar uma vez por pedido
  @@index([reviewedId])
  @@index([orderId])
  @@index([rating])
  @@index([createdAt])
}

model PriceQuote {
  id String @id @default(cuid())

  cryptoType String
  brlPrice   Decimal @db.Decimal(38, 18)
  source     String  @default("coingecko")

  createdAt DateTime @default(now())
}

// SECURITY: Refresh tokens para sessões persistentes
model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

// SECURITY (H-2): Blacklist de access tokens revogados (logout invalida token imediatamente)
// Limpar periodicamente tokens expirados para manter a tabela pequena
model RevokedToken {
  id        String   @id @default(cuid())
  jti       String   @unique // JWT ID (claim 'jti') — identificador único do access token
  expiresAt DateTime // Copiar expiresAt do JWT para cleanup automático
  createdAt DateTime @default(now())

  @@index([jti])
  @@index([expiresAt])
}

// SECURITY: Audit Log completo para rastreabilidade de todas as ações críticas
model AuditLog {
  id String @id @default(cuid())

  // Quem fez a ação
  userId String? // Pode ser null para ações do sistema
  email  String? // Email do usuário (denormalizado para histórico)
  role   String? // Role do usuário no momento da ação
  name   String? // Nome do usuário no momento da ação

  // Ação executada
  action     String // LOGIN, LOGOUT, LOGIN_FAILED, CREATE_ORDER, CANCEL_ORDER, etc
  resource   String // AUTH, ORDER, WALLET, KYC, TRANSACTION, USER, etc
  resourceId String? // ID do recurso afetado (ex: orderId, walletId)

  // Detalhes da ação
  description String? // Descrição legível da ação
  metadata    String? // JSON com dados adicionais (antes/depois, etc)

  // Informações de contexto
  ipAddress    String? // IP do cliente
  userAgent    String? // User-Agent do navegador
  success      Boolean @default(true) // Se a ação foi bem-sucedida
  errorMessage String? // Mensagem de erro se success=false

  // Timestamp
  createdAt DateTime @default(now())

  // Índices para busca rápida
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([success])
  @@index([ipAddress])
}

// Audit log de ações administrativas
model AdminAction {
  id String @id @default(cuid())

  adminId String // ID do admin que executou a ação
  admin   User   @relation(fields: [adminId], references: [id])

  action     String // CREATE, UPDATE, DELETE, APPROVE, REJECT, etc
  resource   String // USER, ORDER, WALLET, KYC, etc
  resourceId String? // ID do recurso afetado

  metadata String? // JSON com dados adicionais
  ip       String? // IP do admin

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([resource])
  @@index([createdAt])
}

// Sistema completo de Disputas
model Dispute {
  id String @id @default(cuid())

  // Relacionamento
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  // Quem criou a disputa
  createdBy String
  creator   User   @relation("DisputeCreator", fields: [createdBy], references: [id])

  // Status: OPEN, UNDER_REVIEW, RESOLVED_BUYER, RESOLVED_SELLER, CANCELLED
  status String @default("OPEN")

  // Categoria: PAYMENT_NOT_RECEIVED, PAYMENT_ISSUE, FRAUD, OTHER
  category String

  // Descrição inicial
  title       String
  description String

  // Resolução (quando resolvida)
  resolvedBy String?
  resolver   User?   @relation("DisputeResolver", fields: [resolvedBy], references: [id])

  resolution     String? // Descrição da resolução
  resolutionType String? // REFUND_BUYER, RELEASE_SELLER, PARTIAL_REFUND, CANCELLED

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages DisputeMessage[]

  @@index([orderId])
  @@index([transactionId])
  @@index([createdBy])
  @@index([status])
  @@index([createdAt])
}

// Mensagens/Evidências de Disputa
model DisputeMessage {
  id String @id @default(cuid())

  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  // Autor (pode ser usuário ou admin)
  authorId String
  author   User   @relation("DisputeMessageAuthor", fields: [authorId], references: [id])

  // Conteúdo
  message String

  // Evidências (URLs de imagens/documentos)
  attachments String? // JSON array de URLs

  // Se é mensagem do sistema/admin
  isAdminMessage Boolean @default(false)

  // Chat privado: userId destinatário (null = visível para todos)
  visibleTo String?

  createdAt DateTime @default(now())

  @@index([disputeId])
  @@index([authorId])
  @@index([createdAt])
  @@index([visibleTo])
}

// ============================================
// SISTEMA DE TICKETS DE SUPORTE
// ============================================

// Ticket de suporte (usuário ↔ plataforma)
model SupportTicket {
  id String @id @default(cuid())

  // Criador do ticket
  createdBy String
  creator   User   @relation("TicketCreator", fields: [createdBy], references: [id])

  // Status do ticket
  status String @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED, CLOSED

  // Categoria e prioridade
  category String // ACCOUNT_ISSUE, PAYMENT_ISSUE, TECHNICAL_ISSUE, KYC_ISSUE, WALLET_ISSUE, QUESTION, FEATURE_REQUEST, OTHER
  priority String @default("MEDIUM") // URGENT, HIGH, MEDIUM, LOW

  // Conteúdo
  subject     String // Assunto (5-200 caracteres)
  description String // Descrição inicial

  // Resolução
  resolvedBy String?
  resolver   User?   @relation("TicketResolver", fields: [resolvedBy], references: [id])
  resolution String?
  resolvedAt DateTime?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages TicketMessage[]

  @@index([createdBy])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
}

// Mensagens do ticket
model TicketMessage {
  id String @id @default(cuid())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("TicketMessageAuthor", fields: [authorId], references: [id])

  message     String
  attachments String? // JSON array

  isSupportMessage Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([authorId])
  @@index([createdAt])
}

// Sistema completo de Notificações
model Notification {
  id String @id @default(cuid())

  // Destinatário
  userId String
  user   User   @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)

  // Tipo de notificação
  type     String // ORDER_MATCHED, PAYMENT_RECEIVED, DEPOSIT_CONFIRMED, REVIEW_RECEIVED, etc
  category String // ORDER, TRANSACTION, DISPUTE, REVIEW, WALLET, KYC, SYSTEM

  // Conteúdo
  title   String
  message String

  // Link/Ação
  actionUrl   String? // URL para onde o usuário deve ir
  actionLabel String? // Texto do botão (ex: "Ver pedido", "Responder disputa")

  // Recurso relacionado
  relatedId   String? // ID do pedido, transação, disputa, etc
  relatedType String? // ORDER, TRANSACTION, DISPUTE, REVIEW

  // Prioridade: LOW, NORMAL, HIGH, URGENT
  priority String @default("NORMAL")

  // Metadata adicional (JSON)
  metadata String?

  // Estado
  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([category])
  @@index([isRead])
  @@index([createdAt])
  @@index([priority])
}

// Log de Broadcasts enviados pelo admin (auditoria)
model BroadcastLog {
  id String @id @default(cuid())

  // Admin que enviou
  adminId    String
  adminEmail String

  // Conteúdo
  title   String
  message String

  // Configuração
  priority        String @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  deliveryChannel String @default("NOTIFICATION") // NOTIFICATION, EMAIL, BOTH
  targetMode      String @default("ALL") // ALL, SELECTED
  actionUrl       String?
  actionLabel     String?

  // Resultado
  recipientCount Int
  recipientIds   String? // JSON array of user IDs (only for SELECTED mode)

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// Sistema completo de Chat em Tempo Real
model Chat {
  id String @id @default(cuid())

  // Relacionamento com pedido
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Participantes (vendedor e comprador)
  participant1Id String
  participant1   User   @relation("ChatParticipant1", fields: [participant1Id], references: [id])

  participant2Id String
  participant2   User   @relation("ChatParticipant2", fields: [participant2Id], references: [id])

  // Status do chat
  isActive Boolean @default(true)

  // Última atividade
  lastMessageAt DateTime?

  // Mensagens não lidas por participante
  unreadCount1 Int @default(0) // Não lidas pelo participant1
  unreadCount2 Int @default(0) // Não lidas pelo participant2

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
  archives ChatArchive[]

  @@index([orderId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
  @@index([isActive])
}

// Mensagens do Chat
model ChatMessage {
  id String @id @default(cuid())

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // Autor da mensagem
  senderId String
  sender   User   @relation("ChatMessageSender", fields: [senderId], references: [id])

  // Conteúdo (retrocompatibilidade)
  message String? // Mensagens antigas (sem criptografia)

  // Criptografia end-to-end
  encryptedContent       String? // Criptografado para o DESTINATÁRIO (chave pública do recipient)
  encryptedForSender     String? // Criptografado para o REMETENTE (chave pública do sender)
  isEncrypted            Boolean @default(false) // Flag de controle
  iv                     String? // IV para encryptedContent (destinatário)
  ivForSender            String? // IV para encryptedForSender (remetente)

  // Anexos (URLs de imagens)
  attachments    String? // JSON array de URLs (retrocompatibilidade)
  attachmentUrl  String? // URL do anexo (novo formato simples)
  attachmentType String? // Tipo MIME do anexo (image/png, image/jpeg, application/pdf)

  // Status de leitura
  isRead Boolean   @default(false)
  readAt DateTime?

  // Tipo de mensagem
  type String @default("TEXT") // TEXT, IMAGE, SYSTEM

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isRead])
}

// Sistema de Arquivamento de Chat (Retenção de 1 ano)
model ChatArchive {
  id String @id @default(cuid())

  // Referência ao chat original
  originalChatId String
  originalChat   Chat   @relation(fields: [originalChatId], references: [id], onDelete: Cascade)

  // Razão do arquivamento
  reason String // ORDER_COMPLETED, ORDER_CANCELLED, ORDER_EXPIRED, MANUAL_ARCHIVE

  // Snapshot das mensagens arquivadas (JSON)
  messagesSnapshot String // JSON array de todas as mensagens no momento do arquivamento

  // Metadados do arquivamento
  archivedBy String? // userId do admin que arquivou (null se automático)
  archivedAt DateTime @default(now())

  // Política de retenção (1 ano)
  expiresAt DateTime // archivedAt + 1 ano

  // Se já foi limpo
  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([originalChatId])
  @@index([reason])
  @@index([expiresAt])
  @@index([isDeleted])
  @@index([archivedAt])
}

// Chaves de criptografia end-to-end para chat
model UserKeys {
  id String @id @default(cuid())

  // Relacionamento 1:1 com User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Chave pública RSA em formato PEM (armazenada no servidor)
  publicKey String // Base64 encoded public key

  // Backup da chave privada criptografada com senha do usuário
  encryptedPrivateKeyBackup String? // Para recuperação em novos dispositivos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Sistema de Histórico de Cancelamentos e Penalidades
model CancellationHistory {
  id String @id @default(cuid())

  // Quem cancelou
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pedido cancelado
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Papel do usuário no pedido
  role String // SELLER (criador) ou BUYER (pagador)

  // Motivo do cancelamento
  reason String // USER_CHANGED_MIND, FOUND_BETTER_PRICE, PAYMENT_ISSUE, etc
  note   String? // Observação adicional do usuário

  // Penalidade aplicada
  penaltyApplied   Boolean @default(false) // Se houve penalidade
  penaltyPoints    Int     @default(0) // Pontos de penalidade aplicados
  reputationBefore Int? // Reputação antes da penalidade
  reputationAfter  Int? // Reputação após a penalidade

  // Contexto do cancelamento
  orderStatus String  // Status do pedido no momento do cancelamento
  orderValue  Decimal @db.Decimal(38, 18) // Valor do pedido (para análise)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([role])
  @@index([createdAt])
  @@index([penaltyApplied])
}

// ============================================
// RBAC SYSTEM - Dynamic Role-Based Access Control
// ============================================

// Roles dinâmicos - podem ser criados via UI por MASTER
model Role {
  id String @id @default(cuid())

  // Identificação
  name        String @unique // Ex: "Analista Financeiro", "Moderador"
  slug        String @unique // Ex: "analista_financeiro", "moderador" (URL-friendly)
  description String? // Descrição do que esse role faz

  // UI
  color String @default("#6B7280") // Cor em hex para exibição (badge)
  icon  String @default("👤") // Emoji ou ícone para UI

  // Sistema
  isSystem Boolean @default(false) // Se é role de sistema (MASTER, USER) - não pode ser deletado
  isActive Boolean @default(true) // Se está ativo (roles podem ser desativados sem deletar)

  // Hierarquia (quanto maior, mais permissões)
  level Int @default(0) // MASTER=100, ADMIN=80, GERENTE=60, SUPPORT=40, USER=0

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  users           User[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@index([isSystem])
  @@index([isActive])
  @@index([level])
}

// Permissões granulares - cada ação específica na plataforma
model Permission {
  id String @id @default(cuid())

  // Identificação
  name        String @unique // Ex: "users.view", "orders.edit", "finance.transfer"
  displayName String // Nome legível: "Visualizar Usuários", "Editar Pedidos"

  // Categoria para agrupar permissões na UI
  category    String // users, orders, disputes, finance, kyc, reports, system

  // Descrição detalhada do que a permissão permite
  description String?

  // Se é permissão crítica (requer 2FA ou atenção especial)
  isCritical Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  rolePermissions RolePermission[]

  @@index([name])
  @@index([category])
  @@index([isCritical])
}

// Tabela de junção Many-to-Many: Role <-> Permission
model RolePermission {
  id String @id @default(cuid())

  // Foreign keys
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Metadados
  grantedBy String? // ID do MASTER que concedeu essa permissão
  grantedAt DateTime @default(now())

  @@unique([roleId, permissionId]) // Um role não pode ter a mesma permissão duplicada
  @@index([roleId])
  @@index([permissionId])
}

// ============================================
// WORKER STATE PERSISTENCE - Tracks worker on/off state across restarts
// ============================================

// Worker State Persistence - Tracks worker on/off state across restarts
model WorkerState {
  id String @id @default(cuid())

  // Unique identifier for the worker (e.g., "BalanceSyncWorker")
  workerName String @unique

  // State: is worker enabled?
  isEnabled Boolean @default(false)

  // Lifecycle timestamps
  lastStartedAt  DateTime?
  lastStoppedAt  DateTime?

  // Standard timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for queries
  @@index([isEnabled])
  @@index([workerName])
}

// ============================================
// EXCHANGE RATE - Tabela de taxas de câmbio para auditoria e cache
// ============================================

// Tabela de taxas de câmbio para auditoria e cache
model ExchangeRate {
  id String @id @default(cuid())

  rate         Decimal @db.Decimal(38, 18) // Taxa USD/BRL
  source       String  // awesomeapi, banco_central, coingecko_brz, etc
  responseTime Int // Tempo de resposta em ms
  timestamp    DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([source])
  @@index([timestamp])
}

// ============================================
// COUPON DISCOUNT SYSTEM
// ============================================

// Cupons de desconto criados por ADMIN/MASTER
model Coupon {
  id String @id @default(cuid())

  // Código único do cupom (ex: "WELCOME50", "PROMO2024")
  code String @unique

  // Desconto aplicado (1-100%)
  discountPercentage Int // Percentual de desconto aplicado SOMENTE à platform fee

  // Limites de uso
  maxUsesPerUser Int      // Quantas vezes cada usuário pode usar
  expiresAt      DateTime? // Data de expiração (null = sem expiração)

  // Visibilidade
  isPublic Boolean @default(false) // true = aparece na lista pública, false = só via código

  // Estado
  isActive Boolean @default(true) // Se o cupom está ativo

  // Estatísticas
  totalUses Int @default(0) // Total de vezes que foi usado

  // Metadados
  description String? // Descrição opcional do cupom
  createdBy   String? // ID do admin que criou
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  userCoupons UserCoupon[]

  @@index([code])
  @@index([isActive])
  @@index([isPublic])
  @@index([expiresAt])
  @@index([createdAt])
}

// Relacionamento Many-to-Many: User <-> Coupon (com tracking de uso)
model UserCoupon {
  id String @id @default(cuid())

  // Relacionamentos
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  // Status
  isActive  Boolean @default(false) // Se este cupom está ativo para o usuário
  timesUsed Int     @default(0)     // Quantas vezes o usuário usou este cupom

  // Timestamps
  activatedAt   DateTime? // Quando foi ativado
  deactivatedAt DateTime? // Quando foi desativado
  firstUsedAt   DateTime? // Primeira vez que foi usado
  lastUsedAt    DateTime? // Última vez que foi usado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, couponId]) // Um usuário não pode ter o mesmo cupom duplicado
  @@index([userId])
  @@index([couponId])
  @@index([isActive])
  @@index([activatedAt])
}

// ============================================
// DUAL-APPROVAL SYSTEM (Maker-Checker)
// ============================================

// Operações financeiras críticas aguardando aprovação do segundo MASTER
model PendingApproval {
  id String @id @default(cuid())

  // Identidade da operação
  // INTERNAL_TRANSFER | ADJUST_BALANCE | PLATFORM_REFUND | LOCK_BALANCE | UNLOCK_BALANCE
  operationType    String
  operationPayload String // JSON.stringify dos parâmetros completos

  // Iniciador (Maker)
  initiatorId   String
  initiator     User    @relation("PendingApprovalInitiator", fields: [initiatorId], references: [id])
  initiatorNote String?

  // Aprovador (Checker)
  approverId   String?
  approver     User?   @relation("PendingApprovalApprover", fields: [approverId], references: [id])
  approverNote String?

  // Status lifecycle:
  // PENDING_APPROVAL → APPROVED | REJECTED | EXPIRED | OVERRIDE_PENDING | OVERRIDE_EXECUTED | OVERRIDE_CANCELLED
  status    String   @default("PENDING_APPROVAL")
  expiresAt DateTime // createdAt + 48h

  // Emergency Override (Cenário A)
  overrideRequestedAt   DateTime?
  overrideExecuteAfter  DateTime? // requestedAt + 30min
  overrideJustification String?   // mínimo 50 chars
  overrideCancelToken   String?   @unique // crypto.randomBytes(32).toString('hex')
  overrideCancelledBy   String?   // userId ou "EMAIL_TOKEN"
  overrideCancelledAt   DateTime?

  // Delegação usada (se aprovado por delegado — Cenário B)
  delegationId String?
  delegation   MasterDelegation? @relation(fields: [delegationId], references: [id])

  // Resultado da execução
  executedAt     DateTime?
  executionError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([initiatorId])
  @@index([expiresAt])
  @@index([overrideCancelToken])
  @@index([createdAt])
}

// Delegação temporária de aprovação para ADMIN/GERENTE (Cenário B)
model MasterDelegation {
  id String @id @default(cuid())

  // Quem concedeu (deve ser MASTER)
  grantorId String
  grantor   User   @relation("DelegationGrantor", fields: [grantorId], references: [id])

  // Quem recebeu (deve ser GERENTE ou ADMIN — nível 60-80)
  granteeId String
  grantee   User   @relation("DelegationGrantee", fields: [granteeId], references: [id])

  // Escopo: JSON array de operationTypes; "[]" significa todos os 5 tipos
  operationScope String @default("[]")

  // Motivo obrigatório
  reason String

  // Período de validade
  startsAt  DateTime @default(now())
  expiresAt DateTime // máximo startsAt + 30 dias

  // Revogação
  isRevoked   Boolean   @default(false)
  revokedById String?
  revokedBy   User?     @relation("DelegationRevoker", fields: [revokedById], references: [id])
  revokedAt   DateTime?
  revokeReason String?

  // Estatísticas de uso
  timesUsed  Int       @default(0)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Aprovações feitas usando esta delegação
  approvals PendingApproval[]

  @@index([granteeId])
  @@index([grantorId])
  @@index([isRevoked])
  @@index([expiresAt])
  @@index([createdAt])
}
